{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cursivis.local/schema/agent-response.schema.json",
  "title": "AgentResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocolVersion",
    "requestId",
    "action",
    "result",
    "confidence",
    "alternatives",
    "latencyMs",
    "timestampUtc"
  ],
  "properties": {
    "protocolVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "requestId": {
      "type": "string",
      "format": "uuid"
    },
    "action": {
      "type": "string"
    },
    "result": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "alternatives": {
      "type": "array",
      "items": { "type": "string" }
    },
    "latencyMs": {
      "type": "integer",
      "minimum": 0
    },
    "model": {
      "type": "string"
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputTokens": { "type": "integer", "minimum": 0 },
        "outputTokens": { "type": "integer", "minimum": 0 }
      }
    },
    "timestampUtc": {
      "type": "string",
      "format": "date-time"
    }
  }
}
