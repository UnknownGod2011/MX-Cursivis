<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="Brush.SurfaceDeep" Color="#FF0F1114" />
    <SolidColorBrush x:Key="Brush.SurfaceMid" Color="#FF13161A" />
    <SolidColorBrush x:Key="Brush.SurfaceHigh" Color="#FF181C21" />
    <SolidColorBrush x:Key="Brush.SurfaceGlass" Color="#DD171B20" />
    <SolidColorBrush x:Key="Brush.StrokeSoft" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="Brush.StrokeStrong" Color="#46FFFFFF" />
    <SolidColorBrush x:Key="Brush.TextMain" Color="#FFF5F7FA" />
    <SolidColorBrush x:Key="Brush.TextMuted" Color="#FFA9B0B8" />
    <SolidColorBrush x:Key="Brush.TextSoft" Color="#FF7A828C" />
    <SolidColorBrush x:Key="Brush.Cyan" Color="#FFF5F7FA" />
    <SolidColorBrush x:Key="Brush.Magenta" Color="#FFD9DEE4" />
    <SolidColorBrush x:Key="Brush.Gold" Color="#FFB9C0C8" />
    <SolidColorBrush x:Key="Brush.WindowBorder" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="Brush.HeroBadgeBackground" Color="#22181C21" />
    <SolidColorBrush x:Key="Brush.HeroBadgeBorder" Color="#26FFFFFF" />
    <SolidColorBrush x:Key="Brush.HeroBadgeText" Color="#FFE8ECF1" />
    <SolidColorBrush x:Key="Brush.SectionBackground" Color="#B014181D" />
    <SolidColorBrush x:Key="Brush.SectionBorder" Color="#18FFFFFF" />
    <SolidColorBrush x:Key="Brush.SectionAccentBorder" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="Brush.ResultPanelShell" Color="#EA171B20" />
    <SolidColorBrush x:Key="Brush.ResultPanelStroke" Color="#00FFFFFF" />
    <SolidColorBrush x:Key="Brush.ResultPanelHeader" Color="#801A1E23" />
    <SolidColorBrush x:Key="Brush.ResultPanelSurface" Color="#A0111418" />
    <SolidColorBrush x:Key="Brush.ResultPanelSurfaceBorder" Color="#1CFFFFFF" />
    <SolidColorBrush x:Key="Brush.ResultActionBadgeBackground" Color="#00FFFFFF" />
    <SolidColorBrush x:Key="Brush.ResultActionBadgeBorder" Color="#00FFFFFF" />
    <SolidColorBrush x:Key="Brush.ResultActionBadgeText" Color="#FFA9B0B8" />
    <SolidColorBrush x:Key="Brush.ButtonPrimaryBackground" Color="#1CFFFFFF" />
    <SolidColorBrush x:Key="Brush.ButtonPrimaryBorder" Color="#26FFFFFF" />
    <SolidColorBrush x:Key="Brush.ButtonPrimaryText" Color="#FFF7FAFF" />
    <SolidColorBrush x:Key="Brush.ButtonSecondaryBackground" Color="#12FFFFFF" />
    <SolidColorBrush x:Key="Brush.ButtonSecondaryBorder" Color="#18FFFFFF" />
    <SolidColorBrush x:Key="Brush.ButtonSecondaryText" Color="#FFA9B0B8" />
    <SolidColorBrush x:Key="Brush.ButtonAccentBackground" Color="#FFF5F7FA" />
    <SolidColorBrush x:Key="Brush.ButtonAccentBorder" Color="#FFF5F7FA" />
    <SolidColorBrush x:Key="Brush.ButtonAccentText" Color="#FF111418" />
    <SolidColorBrush x:Key="Brush.InputBackground" Color="#9012161A" />
    <SolidColorBrush x:Key="Brush.InputBorder" Color="#1EFFFFFF" />
    <SolidColorBrush x:Key="Brush.InputForeground" Color="#FFF7FAFD" />
    <SolidColorBrush x:Key="Brush.ResultHeadingText" Color="#FFF7FAFD" />
    <SolidColorBrush x:Key="Brush.ResultMetaText" Color="#FFA9B0B8" />
    <SolidColorBrush x:Key="Brush.ResultBulletText" Color="#FFD4DAE1" />
    <SolidColorBrush x:Key="Brush.ResultCodeForeground" Color="#FFF2F5FA" />
    <SolidColorBrush x:Key="Brush.ResultCodeBackground" Color="#241A1D21" />
    <SolidColorBrush x:Key="Brush.ResultMathForeground" Color="#FFE9EDF2" />
    <SolidColorBrush x:Key="Brush.ResultMathBackground" Color="#22171B20" />

    <LinearGradientBrush x:Key="Brush.WindowGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF0B0D10" Offset="0" />
        <GradientStop Color="#FF101317" Offset="0.5" />
        <GradientStop Color="#FF14181C" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.CardGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F014171B" Offset="0" />
        <GradientStop Color="#F0181C21" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.PrimaryButtonGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1CFFFFFF" Offset="0" />
        <GradientStop Color="#16FFFFFF" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.AccentButtonGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFF5F7FA" Offset="0" />
        <GradientStop Color="#FFE9EDF1" Offset="1" />
    </LinearGradientBrush>

    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextMain}" />
    </Style>

    <Style x:Key="HeadlineTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Display Semibold, Segoe UI Semibold" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextMain}" />
    </Style>

    <Style x:Key="SubtleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
    </Style>

    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceHigh}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextMain}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.InputBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="HasDropShadow" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            SnapsToDevicePixels="True">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GlassTextBoxStyle" TargetType="TextBox">
        <Setter Property="Foreground" Value="{DynamicResource Brush.InputForeground}" />
        <Setter Property="Background" Value="{DynamicResource Brush.InputBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.InputBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="13,9" />
        <Setter Property="CaretBrush" Value="{DynamicResource Brush.Cyan}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Brush.ButtonAccentBackground}" />
        <Setter Property="SelectionOpacity" Value="0.82" />
        <Setter Property="TextBoxBase.SelectionTextBrush" Value="{DynamicResource Brush.ButtonAccentText}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="TextBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="16"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      Foreground="{TemplateBinding Foreground}"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"
                                      CanContentScroll="False"
                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TextBorder" Property="BorderBrush" Value="{DynamicResource Brush.StrokeStrong}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="TextBorder" Property="BorderBrush" Value="{DynamicResource Brush.StrokeStrong}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GlassComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Foreground" Value="{DynamicResource Brush.InputForeground}" />
        <Setter Property="Background" Value="{DynamicResource Brush.InputBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.InputBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="ComboRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="34" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Margin="12,6,10,6"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                                <ToggleButton Grid.Column="1"
                                              Focusable="False"
                                              ClickMode="Press"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                    <Path Width="10"
                                          Height="6"
                                          Stretch="Fill"
                                          Fill="{TemplateBinding Foreground}"
                                          Data="M0,0 L5,6 L10,0 Z" />
                                </ToggleButton>
                            </Grid>
                        </Border>
                        <Popup Name="Popup"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               PopupAnimation="Fade">
                            <Border Margin="0,8,0,0"
                                    Background="{DynamicResource Brush.SurfaceGlass}"
                                    BorderBrush="{DynamicResource Brush.InputBorder}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="8">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ComboRoot" Property="BorderBrush" Value="{DynamicResource Brush.StrokeStrong}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextMain}" />
        <Setter Property="Background" Value="{DynamicResource Brush.SurfaceGlass}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.SurfaceMid}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.SurfaceHigh}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="GlassListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextMain}" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
    </Style>

    <Style x:Key="GlassListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,0,10" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Outer"
                            CornerRadius="16"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource Brush.SectionBorder}"
                            Background="{DynamicResource Brush.SectionBackground}"
                            Padding="14,12">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource Brush.SectionAccentBorder}" />
                            <Setter TargetName="Outer" Property="Background" Value="{DynamicResource Brush.SurfaceGlass}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="Background" Value="{DynamicResource Brush.SurfaceGlass}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GlassButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Brush.ButtonPrimaryText}" />
        <Setter Property="Background" Value="{DynamicResource Brush.ButtonPrimaryBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.ButtonPrimaryBorder}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text Semibold, Segoe UI Semibold" />
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="OuterBorder"
                                CornerRadius="15"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10"
                                                  ShadowDepth="0"
                                                  Color="#24000000"
                                                  Opacity="0.08" />
                            </Border.Effect>
                        </Border>
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource Brush.StrokeStrong}" />
                            <Setter TargetName="OuterBorder" Property="Opacity" Value="0.98" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="OuterBorder" Property="Opacity" Value="0.9" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.42" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.ButtonAccentBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.ButtonAccentBorder}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.ButtonAccentText}" />
    </Style>

    <Style x:Key="MutedButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.ButtonSecondaryBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.ButtonSecondaryBorder}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.ButtonSecondaryText}" />
    </Style>

    <Style x:Key="PanelToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassButtonStyle}">
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="11.5" />
    </Style>

    <Style x:Key="PanelIconButtonStyle" TargetType="Button" BasedOn="{StaticResource GlassButtonStyle}">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextMain}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="GlassSliderStyle" TargetType="Slider">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Cyan}" />
        <Setter Property="Background" Value="{DynamicResource Brush.SectionBackground}" />
        <Setter Property="Height" Value="32" />
    </Style>

    <Style x:Key="ThinRepeatButtonStyle" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ThinThumbStyle" TargetType="Thumb">
        <Setter Property="Background" Value="{DynamicResource Brush.TextMain}" />
        <Setter Property="Opacity" Value="0.42" />
        <Setter Property="MinHeight" Value="18" />
        <Setter Property="MinWidth" Value="18" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid Background="Transparent">
                        <Ellipse Width="6"
                                 Height="6"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                 Fill="{TemplateBinding Background}"
                                 SnapsToDevicePixels="True">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="8"
                                                  ShadowDepth="0"
                                                  Color="#33000000"
                                                  Opacity="0.14" />
                            </Ellipse.Effect>
                        </Ellipse>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ThinScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Width" Value="10" />
        <Setter Property="Height" Value="10" />
        <Setter Property="Opacity" Value="0.92" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent" Margin="0,2">
                        <Track x:Name="PART_Track"
                               IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ThinRepeatButtonStyle}"
                                              Command="ScrollBar.LineUpCommand" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ThinThumbStyle}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ThinRepeatButtonStyle}"
                                              Command="ScrollBar.LineDownCommand" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Width" Value="Auto" />
                            <Setter Property="Height" Value="8" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
