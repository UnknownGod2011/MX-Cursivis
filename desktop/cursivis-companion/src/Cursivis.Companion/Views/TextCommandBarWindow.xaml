<Window x:Class="Cursivis.Companion.Views.TextCommandBarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="300"
        Height="78"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        ShowActivated="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Deactivated="Window_OnDeactivated"
        KeyDown="Window_OnKeyDown">
    <Border x:Name="ShellBorder"
            Background="{DynamicResource Brush.ResultPanelShell}"
            BorderBrush="{DynamicResource Brush.ResultPanelSurfaceBorder}"
            BorderThickness="1"
            CornerRadius="24"
            Padding="10"
            PreviewMouseLeftButtonDown="ShellBorder_OnPreviewMouseLeftButtonDown"
            PreviewMouseMove="ShellBorder_OnPreviewMouseMove"
            PreviewMouseLeftButtonUp="ShellBorder_OnPreviewMouseLeftButtonUp">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="0"
                              Color="#33000000"
                              Opacity="0.16" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="10" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="DragHandle"
                    Grid.Row="0"
                    Background="Transparent"
                    Cursor="SizeAll"
                    PreviewMouseLeftButtonDown="DragHandle_OnPreviewMouseLeftButtonDown"
                    PreviewMouseMove="DragHandle_OnPreviewMouseMove"
                    PreviewMouseLeftButtonUp="DragHandle_OnPreviewMouseLeftButtonUp" />

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,10,0">
                    <Border Height="48"
                            Background="{DynamicResource Brush.InputBackground}"
                            BorderBrush="{DynamicResource Brush.InputBorder}"
                            BorderThickness="1"
                            CornerRadius="18"
                            RenderOptions.ClearTypeHint="Enabled"
                            TextOptions.TextFormattingMode="Display">
                        <TextBox x:Name="CommandTextBox"
                                 MinWidth="0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="14,0"
                                 VerticalContentAlignment="Center"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource Brush.InputForeground}"
                                 CaretBrush="{DynamicResource Brush.InputForeground}"
                                 TextBoxBase.SelectionBrush="{DynamicResource Brush.ButtonAccentBackground}"
                                 TextBoxBase.SelectionTextBrush="{DynamicResource Brush.ButtonAccentText}"
                                 FontFamily="Segoe UI Variable Text, Segoe UI"
                                 FontSize="15"
                                 FontWeight="SemiBold"
                                 TextOptions.TextFormattingMode="Display"
                                 TextAlignment="Left"
                                 TextWrapping="NoWrap"
                                 AcceptsReturn="False"
                                 TextChanged="CommandTextBox_OnTextChanged" />
                    </Border>
                    <TextBlock x:Name="PlaceholderText"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.TextSoft}"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               IsHitTestVisible="False"
                               Text="Type a refinement or follow-up..." />
                </Grid>

                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Width="46"
                        Height="46"
                        Style="{StaticResource GlassButtonStyle}"
                        Click="SendButton_OnClick"
                        ToolTip="Send text instruction">
                    <TextBlock Text="&#xE724;"
                               FontFamily="Segoe Fluent Icons"
                               FontSize="15"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
