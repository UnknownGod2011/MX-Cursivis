<Window x:Class="Cursivis.Companion.Views.OrbOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        AllowsTransparency="True"
        Background="Transparent"
        Height="320"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        Width="320"
        WindowStyle="None"
        Loaded="Window_OnLoaded">
    <Grid>
        <Canvas Width="320" Height="320">
            <Border x:Name="ActionChipTop"
                    Width="94"
                    Height="32"
                    CornerRadius="16"
                    Canvas.Left="113"
                    Canvas.Top="40"
                    Background="#BA111C27"
                    BorderBrush="#40FFFFFF"
                    BorderThickness="1"
                    MouseLeftButtonUp="ActionChip_OnMouseLeftButtonUp">
                <TextBlock x:Name="ActionTopText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="10"
                           FontFamily="Bahnschrift SemiBold"
                           Text="Summarize" />
            </Border>

            <Border x:Name="ActionChipUpperRight"
                    Width="94"
                    Height="32"
                    CornerRadius="16"
                    Canvas.Left="220"
                    Canvas.Top="104"
                    Background="#BA111C27"
                    BorderBrush="#40FFFFFF"
                    BorderThickness="1"
                    MouseLeftButtonUp="ActionChip_OnMouseLeftButtonUp">
                <TextBlock x:Name="ActionUpperRightText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="10"
                           FontFamily="Bahnschrift SemiBold"
                           Text="Rewrite" />
            </Border>

            <Border x:Name="ActionChipLowerRight"
                    Width="94"
                    Height="32"
                    CornerRadius="16"
                    Canvas.Left="220"
                    Canvas.Top="184"
                    Background="#BA111C27"
                    BorderBrush="#40FFFFFF"
                    BorderThickness="1"
                    MouseLeftButtonUp="ActionChip_OnMouseLeftButtonUp">
                <TextBlock x:Name="ActionLowerRightText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="10"
                           FontFamily="Bahnschrift SemiBold"
                           Text="Translate" />
            </Border>

            <Border x:Name="ActionChipLowerLeft"
                    Width="94"
                    Height="32"
                    CornerRadius="16"
                    Canvas.Left="6"
                    Canvas.Top="184"
                    Background="#BA111C27"
                    BorderBrush="#40FFFFFF"
                    BorderThickness="1"
                    MouseLeftButtonUp="ActionChip_OnMouseLeftButtonUp">
                <TextBlock x:Name="ActionLowerLeftText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="10"
                           FontFamily="Bahnschrift SemiBold"
                           Text="Explain" />
            </Border>

            <Border x:Name="ActionChipUpperLeft"
                    Width="94"
                    Height="32"
                    CornerRadius="16"
                    Canvas.Left="6"
                    Canvas.Top="104"
                    Background="#BA111C27"
                    BorderBrush="#40FFFFFF"
                    BorderThickness="1"
                    MouseLeftButtonUp="ActionChip_OnMouseLeftButtonUp">
                <TextBlock x:Name="ActionUpperLeftText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="10"
                           FontFamily="Bahnschrift SemiBold"
                           Text="Bullet Points" />
            </Border>

            <Grid Width="176"
                  Height="176"
                  Canvas.Left="72"
                  Canvas.Top="72">
                <Canvas Width="176" Height="176" IsHitTestVisible="False">
                    <Ellipse x:Name="MagicRing1"
                             Width="140"
                             Height="140"
                             Canvas.Left="18"
                             Canvas.Top="18"
                             Stroke="#00FFFFFF"
                             StrokeThickness="2"
                             Opacity="0" />
                    <Ellipse x:Name="MagicRing2"
                             Width="150"
                             Height="150"
                             Canvas.Left="13"
                             Canvas.Top="13"
                             Stroke="#00FFFFFF"
                             StrokeThickness="2"
                             Opacity="0" />
                    <Ellipse x:Name="MagicRing3"
                             Width="160"
                             Height="160"
                             Canvas.Left="8"
                             Canvas.Top="8"
                             Stroke="#00FFFFFF"
                             StrokeThickness="2"
                             Opacity="0" />
                    <Ellipse x:Name="MagicRing4"
                             Width="170"
                             Height="170"
                             Canvas.Left="3"
                             Canvas.Top="3"
                             Stroke="#00FFFFFF"
                             StrokeThickness="1.4"
                             Opacity="0" />
                </Canvas>

                <Ellipse x:Name="IdleGlowHalo"
                         Width="126"
                         Height="126"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Opacity="0"
                         IsHitTestVisible="False">
                    <Ellipse.Fill>#00000000</Ellipse.Fill>
                </Ellipse>

                <Ellipse x:Name="VoiceGlowHalo"
                         Width="170"
                         Height="170"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Opacity="0"
                         IsHitTestVisible="False">
                    <Ellipse.Fill>
                        <RadialGradientBrush Center="0.5,0.5"
                                             GradientOrigin="0.5,0.5"
                                             RadiusX="0.5"
                                             RadiusY="0.5">
                            <GradientStop Color="#00000000" Offset="0.00" />
                            <GradientStop Color="#00000000" Offset="0.56" />
                            <GradientStop Color="#00000000" Offset="0.82" />
                            <GradientStop Color="#00000000" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Stroke>
                        <SolidColorBrush Color="#00FFFFFF" />
                    </Ellipse.Stroke>
                    <Ellipse.StrokeThickness>1.4</Ellipse.StrokeThickness>
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="VoiceGlowScaleTransform" ScaleX="1" ScaleY="1" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Ellipse x:Name="GlowHalo"
                         Width="166"
                         Height="166"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Opacity="0"
                         Visibility="Collapsed">
                    <Ellipse.Fill>
                        <RadialGradientBrush Center="0.5,0.5"
                                             GradientOrigin="0.5,0.5"
                                             RadiusX="0.5"
                                             RadiusY="0.5">
                            <GradientStop Color="#00FFFFFF" Offset="0.06" />
                            <GradientStop Color="#00000000" Offset="0.40" />
                            <GradientStop Color="#00000000" Offset="0.86" />
                            <GradientStop Color="#00111418" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="GlowScaleTransform" ScaleX="1" ScaleY="1" />
                    </Ellipse.RenderTransform>
                </Ellipse>

                <Canvas x:Name="OrbitRingCanvas"
                        Width="176" Height="176"
                        IsHitTestVisible="False"
                        Visibility="Collapsed"
                        RenderTransformOrigin="0.5,0.5">
                    <Canvas.RenderTransform>
                        <RotateTransform x:Name="OrbitRotateTransform" Angle="0" />
                    </Canvas.RenderTransform>

                    <Ellipse Width="144"
                             Height="144"
                             Canvas.Left="16"
                             Canvas.Top="16"
                             Stroke="#00FFFFFF"
                             StrokeThickness="1.2"
                             StrokeDashArray="2 7" />
                    <Ellipse Width="160"
                             Height="160"
                             Canvas.Left="8"
                             Canvas.Top="8"
                             Stroke="#00FFFFFF"
                             StrokeThickness="1"
                             StrokeDashArray="1.5 9" />
                </Canvas>

                <Border x:Name="OrbCore"
                        Width="118"
                        Height="118"
                        Background="#F4FFFFFF"
                        BorderBrush="#20000000"
                        BorderThickness="1"
                        CornerRadius="59"
                        Cursor="Arrow"
                        MouseLeftButtonDown="OrbCore_OnMouseLeftButtonDown"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12"
                                          ShadowDepth="0"
                                          Color="#CC08131F"
                                          Opacity="0.18" />
                    </Border.Effect>
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="OrbScaleTransform" ScaleX="0.88" ScaleY="0.88" />
                    </Border.RenderTransform>
                    <Grid>
                        <Button x:Name="ListeningStopButton"
                                Width="22"
                                Height="22"
                                Margin="0,0,18,18"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Panel.ZIndex="20"
                                Visibility="Collapsed"
                                Background="#AAFFFFFF"
                                BorderBrush="#FFFF7B7B"
                                BorderThickness="1"
                                Cursor="Hand"
                                ToolTip="Stop recording"
                                Click="ListeningStopButton_OnClick">
                            <Border Width="9"
                                    Height="9"
                                    Background="#FFFF5F5F"
                                    CornerRadius="1" />
                        </Button>

                        <Ellipse x:Name="OrbInnerSurface"
                                 Margin="6"
                                 Stroke="#14000000"
                                 StrokeThickness="1">
                            <Ellipse.Fill>
                                <RadialGradientBrush GradientOrigin="0.3,0.25">
                                    <GradientStop Color="#FFFDFEFF" Offset="0" />
                                    <GradientStop Color="#FFF5F7F9" Offset="0.58" />
                                    <GradientStop Color="#FFE9EDF1" Offset="1" />
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>

                        <Grid x:Name="ExpandedStatePanel"
                              Margin="10,12,10,10"
                              Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border x:Name="StateBadge"
                                    Grid.Row="0"
                                    MinWidth="64"
                                    Height="19"
                                    Margin="0,0,0,8"
                                    Padding="12,0"
                                    HorizontalAlignment="Center"
                                    CornerRadius="10"
                                    Background="#D9FFFFFF"
                                    BorderBrush="#18000000"
                                    BorderThickness="1">
                                <TextBlock x:Name="StateText"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           FontSize="10.2"
                                           Text="Idle" />
                            </Border>

                            <TextBlock Grid.Row="1"
                                       x:Name="StatusText"
                                       Margin="6,0,6,0"
                                       MaxWidth="84"
                                       VerticalAlignment="Center"
                                       Foreground="#FF161B21"
                                       FontSize="10"
                                       FontFamily="Bahnschrift SemiBold"
                                       HorizontalAlignment="Center"
                                       Text="Ready"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2"
                                       x:Name="BrandText"
                                       Margin="0,8,0,0"
                                       HorizontalAlignment="Center"
                                       Foreground="#FF6B727A"
                                       FontFamily="Bahnschrift"
                                       FontSize="9"
                                       Text="CURSIVIS" />
                        </Grid>

                        <Grid x:Name="CompactIdlePanel"
                              Margin="10"
                              Visibility="Collapsed">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,18">
                                    <Button x:Name="ModePrevButton"
                                            Width="10"
                                            Height="10"
                                            Margin="0,0,4,0"
                                            Padding="0"
                                            Background="#00FFFFFF"
                                            BorderBrush="#00FFFFFF"
                                            Foreground="#FF7A818A"
                                            FontSize="8"
                                            Content="&lt;"
                                            Click="ModePrevButton_OnClick" />
                                    <TextBlock x:Name="ModeText"
                                               VerticalAlignment="Center"
                                               Foreground="#FF1C2127"
                                               FontFamily="Bahnschrift SemiBold"
                                               FontSize="10"
                                               Text="Smart" />
                                    <Button x:Name="ModeNextButton"
                                            Width="10"
                                            Height="10"
                                            Margin="4,0,0,0"
                                            Padding="0"
                                            Background="#00FFFFFF"
                                            BorderBrush="#00FFFFFF"
                                            Foreground="#FF7A818A"
                                            FontSize="8"
                                            Content="&gt;"
                                            Click="ModeNextButton_OnClick" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                    <Button x:Name="CommandPrevButton"
                                            Width="10"
                                            Height="10"
                                            Margin="0,0,4,0"
                                            Padding="0"
                                            VerticalAlignment="Center"
                                            Background="#00FFFFFF"
                                            BorderBrush="#00FFFFFF"
                                            Foreground="#FF7A818A"
                                            FontSize="8"
                                            Content="&lt;"
                                            Click="CommandPrevButton_OnClick" />
                                    <Button x:Name="IdleRunButton"
                                            Width="46"
                                            Height="18"
                                            HorizontalAlignment="Center"
                                            Padding="0"
                                            Background="#D9FFFFFF"
                                            BorderBrush="#18000000"
                                            BorderThickness="1"
                                            Foreground="#FF1B2026"
                                            FontFamily="Bahnschrift SemiBold"
                                            FontSize="8.5"
                                            Content="Trigger"
                                            Click="IdleRunButton_OnClick" />
                                    <Button x:Name="CommandNextButton"
                                            Width="10"
                                            Height="10"
                                            Margin="4,0,0,0"
                                            Padding="0"
                                            VerticalAlignment="Center"
                                            Background="#00FFFFFF"
                                            BorderBrush="#00FFFFFF"
                                            Foreground="#FF7A818A"
                                            FontSize="8"
                                            Content="&gt;"
                                            Click="CommandNextButton_OnClick" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Canvas>
    </Grid>
</Window>
