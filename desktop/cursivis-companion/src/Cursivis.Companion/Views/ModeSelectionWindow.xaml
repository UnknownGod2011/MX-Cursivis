<Window x:Class="Cursivis.Companion.Views.ModeSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose Mode"
        Width="430"
        Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Border Background="#FF101722" Padding="18">
        <StackPanel>
            <TextBlock FontSize="18"
                       FontWeight="Bold"
                       Foreground="White"
                       Text="Welcome to Cursivis" />
            <TextBlock Margin="0,8,0,14"
                       Foreground="#B4D8EA"
                       Text="Choose your interaction mode. You can change this later." />
            <StackPanel Orientation="Horizontal">
                <Button Width="180"
                        Height="74"
                        Margin="0,0,12,0"
                        Content="Smart Mode (AutoPerform)"
                        Click="Smart_Click" />
                <Button Width="180"
                        Height="74"
                        Content="Guided Mode (Manual)"
                        Click="Guided_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
