<Window x:Class="Cursivis.Companion.Views.ResultPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Height="312"
        ShowInTaskbar="False"
        Topmost="True"
        Width="612"
        MinWidth="516"
        MinHeight="232"
        WindowStyle="None">
    <Border x:Name="RootCard"
            CornerRadius="28"
            Background="{DynamicResource Brush.ResultPanelShell}"
            BorderBrush="Transparent"
            BorderThickness="0"
            Padding="12"
            MouseLeftButtonDown="RootCard_OnMouseLeftButtonDown">
        <Border.RenderTransform>
            <TranslateTransform x:Name="PanelTranslateTransform" Y="14" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              ShadowDepth="0"
                              Color="#66000000"
                              Opacity="0.24" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="DragHeader"
                    Grid.Row="0"
                    Background="{DynamicResource Brush.ResultPanelHeader}"
                    CornerRadius="18"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="TitleText"
                               Style="{StaticResource HeadlineTextStyle}"
                               FontSize="17"
                               VerticalAlignment="Center"
                               Text="Cursivis" />

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                        <Button x:Name="UndoButton"
                                MinWidth="50"
                                Height="28"
                                Margin="0,0,6,0"
                                Style="{StaticResource PanelToolbarButtonStyle}"
                                Content="Undo"
                                IsEnabled="False"
                                Click="UndoButton_OnClick" />
                        <Button x:Name="InsertButton"
                                MinWidth="58"
                                Height="28"
                                Margin="0,0,6,0"
                                Style="{StaticResource PanelToolbarButtonStyle}"
                                Content="Insert"
                                Click="InsertButton_OnClick" />
                        <Button x:Name="TakeActionButton"
                                Margin="0,0,6,0"
                                Style="{StaticResource PanelToolbarButtonStyle}"
                                MinWidth="86"
                                Height="28"
                                Content="Take Action"
                                Click="TakeActionButton_OnClick" />
                        <Button x:Name="MoreOptionsButton"
                                MinWidth="88"
                                Height="28"
                                Margin="0,0,6,0"
                                Style="{StaticResource PanelToolbarButtonStyle}"
                                Content="More Options"
                                Click="MoreOptionsButton_OnClick" />
                        <Button x:Name="ThemeToggleButton"
                                Width="34"
                                Margin="0,0,6,0"
                                Style="{StaticResource PanelIconButtonStyle}"
                                FontFamily="Segoe UI Symbol"
                                Click="ThemeToggleButton_OnClick" />
                        <Button x:Name="SettingsButton"
                                Style="{StaticResource PanelIconButtonStyle}"
                                FontFamily="Segoe UI Symbol"
                                ToolTip="Settings"
                                Click="SettingsButton_OnClick" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,8,0,0"
                    CornerRadius="22"
                    Background="{DynamicResource Brush.ResultPanelSurface}"
                    BorderBrush="{DynamicResource Brush.ResultPanelSurfaceBorder}"
                    BorderThickness="1"
                    Padding="12,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource SubtleTextStyle}"
                                   FontSize="10.5"
                                   FontWeight="SemiBold"
                                   Text="Output" />
                        <TextBlock Margin="6,0,6,0"
                                   Style="{StaticResource SubtleTextStyle}"
                                   FontSize="11"
                                   Text="/" />
                        <TextBlock x:Name="ActionText"
                                   Style="{StaticResource SubtleTextStyle}"
                                   FontSize="10.5"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.ResultMetaText}"
                                   Text="System Status" />
                    </StackPanel>

                    <RichTextBox x:Name="ResultDocumentBox"
                                 Grid.Row="1"
                                 Margin="0,7,0,0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{DynamicResource Brush.TextMain}"
                                 Focusable="False"
                                 IsReadOnly="True"
                                 IsReadOnlyCaretVisible="False"
                                 Padding="0"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled">
                        <RichTextBox.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBarStyle}" />
                        </RichTextBox.Resources>
                    </RichTextBox>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
